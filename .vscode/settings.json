{
  "[typescript]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  },
  "deno.enablePaths": [
    "supabase/functions"
  ],
  "deno.lint": true,
  "deno.unstable": [
    "bare-node-builtins",
    "byonm",
    "sloppy-imports",
    "unsafe-proto",
    "webgpu",
    "broadcast-channel",
    "worker-options",
    "cron",
    "kv",
    "ffi",
    "fs",
    "http",
    "net"
  ],
  "window.title": "${rootName}→${activeEditorShort}",
  "files.exclude": {},
  // "explorer.excludeGitIgnore": true,
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "[sql]": {
    "editor.defaultFormatter": "Supabase.postgrestools"
  }
}